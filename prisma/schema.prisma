generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  abbreviation String    @unique
  createdAt    DateTime  @default(now()) @map("created_at")
  programs     Program[]
}

model Program {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  departmentId Int              @map("department_id")
  department   Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("created_at")
  clusters     ClusterProgram[]
}

model Cluster {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String           @default("")
  capacity        Int
  currentEnrolled Int              @default(0) @map("current_enrolled")
  location        String           @default("")
  createdAt       DateTime         @default(now()) @map("created_at")
  staff           Staff[]
  allowedPrograms ClusterProgram[]
  phases          Phase[]
}

model ClusterProgram {
  clusterId Int     @map("cluster_id")
  programId Int     @map("program_id")
  slots     Int     @default(0)
  enrolled  Int     @default(0)
  cluster   Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@id([clusterId, programId])
}

model Staff {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("staff")
  isActive  Boolean   @default(true) @map("is_active")
  clusterId Int       @map("cluster_id")
  cluster   Cluster   @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")
}

model Student {
  id           Int           @id @default(autoincrement())
  studentId    String        @unique @map("student_id")
  fullName     String        @map("full_name")
  department   String
  program      String
  email        String        @unique
  password     String
  role         String        @default("student")
  createdAt    DateTime      @default(now()) @map("created_at")
  applications Application[]
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")
}

model IptSession {
  id            Int      @id @default(autoincrement())
  name          String
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  weeksPerPhase Int      @default(5) @map("weeks_per_phase")
  isActive      Boolean  @default(false) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  phases        Phase[]
}

model Phase {
  id          Int              @id @default(autoincrement())
  sessionId   Int              @map("session_id")
  session     IptSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  phaseNumber Int              @map("phase_number")
  clusterId   Int              @map("cluster_id")
  cluster     Cluster          @relation(fields: [clusterId], references: [id])
  startDate   DateTime         @map("start_date")
  endDate     DateTime         @map("end_date")
  allocations PhaseAllocation[]
  createdAt   DateTime         @default(now()) @map("created_at")

  @@unique([sessionId, phaseNumber, clusterId])
}

model PhaseAllocation {
  id            Int         @id @default(autoincrement())
  phaseId       Int         @map("phase_id")
  phase         Phase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  applicationId Int         @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  clusterId     Int         @map("cluster_id")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([applicationId, phaseId])
}

model WaitlistEntry {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  clusterId     Int         @map("cluster_id")
  status        String      @default("waiting")
  position      Int
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([clusterId, status, position])
}

model TransferRequest {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromClusterId Int         @map("from_cluster_id")
  toClusterId   Int         @map("to_cluster_id")
  reason        String
  status        String      @default("pending")
  reviewNotes   String?     @map("review_notes")
  reviewedById  Int?        @map("reviewed_by_id")
  reviewedAt    DateTime?   @map("reviewed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
}

model Application {
  id               Int               @id @default(autoincrement())
  studentId        Int               @map("student_id")
  student          Student           @relation(fields: [studentId], references: [id])
  clusterPref1     Int               @map("cluster_pref_1")
  clusterPref2     Int               @map("cluster_pref_2")
  status           String            @default("pending")
  allocatedCluster Int?              @map("allocated_cluster")
  waitlistedAt     DateTime?         @map("waitlisted_at")
  reportUrl        String?           @map("report_url")
  submissionDate   DateTime          @default(now()) @map("submission_date")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  allocations      PhaseAllocation[]
  waitlistEntries  WaitlistEntry[]
  transferRequests TransferRequest[]

  @@unique([studentId])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  type      String   @default("string")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String
  category  String   @default("general")
  subject   String
  body      String
  variables String   @default("[]")
  enabled   Boolean  @default(true)
  required  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  recipient String
  subject   String
  template  String?
  status    String   @default("pending")
  error     String?
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")
}
