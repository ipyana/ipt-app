generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  abbreviation String    @unique
  createdAt    DateTime  @default(now()) @map("created_at")
  programs     Program[]
}

model Program {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  departmentId Int              @map("department_id")
  department   Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("created_at")
  clusters     ClusterProgram[]
}

model Cluster {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String           @default("")
  capacity        Int
  currentEnrolled Int              @default(0) @map("current_enrolled")
  location        String           @default("")
  createdAt       DateTime         @default(now()) @map("created_at")
  staff           Staff[]
  allowedPrograms ClusterProgram[]
}

model ClusterProgram {
  clusterId Int     @map("cluster_id")
  programId Int     @map("program_id")
  slots     Int     @default(0)
  enrolled  Int     @default(0)
  cluster   Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@id([clusterId, programId])
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  clusterId Int      @map("cluster_id")
  cluster   Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
}

model Student {
  id           Int           @id @default(autoincrement())
  studentId    String        @unique @map("student_id")
  fullName     String        @map("full_name")
  department   String
  program      String
  email        String        @unique
  password     String
  role         String        @default("student")
  createdAt    DateTime      @default(now()) @map("created_at")
  applications Application[]
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")
}

model Application {
  id               Int      @id @default(autoincrement())
  studentId        Int      @map("student_id")
  student          Student  @relation(fields: [studentId], references: [id])
  clusterPref1     Int      @map("cluster_pref_1")
  clusterPref2     Int      @map("cluster_pref_2")
  clusterPref3     Int      @map("cluster_pref_3")
  status           String   @default("pending")
  allocatedCluster Int?     @map("allocated_cluster")
  reportUrl        String?  @map("report_url")
  submissionDate   DateTime @default(now()) @map("submission_date")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([studentId])
}
